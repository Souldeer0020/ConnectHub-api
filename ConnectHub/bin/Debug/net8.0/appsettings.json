{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=ConnectHubDb;Trusted_Connection=True;TrustServerCertificate=True",
    "Redis": "localhost"
  },
  "JWTSettings": {
    "SecretKey": "7fK9xP2mQ8vL4nT1cR6yW3eH8jZ5uB0a",
    "Issuer": "ConnectHubAPI",
    "Audience": "ConnectHubClient",
    "ExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "FileSettings": {
    "UploadPath": "wwwroot/uploads",
    "BaseUrl": "https://localhost:5190"
  },
    "Serilog": {
      "Using": [
        "Serilog.Sinks.Console",
        "Serilog.Sinks.File"
      ],
      "MinimumLevel": {
        "Default": "Information",
        "Override": {
          "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
        }
      },
      "Enrich": [
        "FromLogContext"
      ],
      "WriteTo": [
        {
          "Name": "Console"
        },
        {
          "Name": "File",
          "Args": {
            "path": "logs/connecthub.txt",
            "rollingInterval": "Day",
            "retainedFileCountLimit": 7
          }
        }
      ]
    }
  ,
  "AllowedHosts": "*"
}
